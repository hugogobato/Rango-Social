# Data source config: mock | supabase
VITE_DATA_SOURCE=mock

# Supabase integration (Phase 12)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Generative Language API Key (Vercel server-side proxy only, Phase 13)
# NEVER expose this key in your client-side code (never use VITE_ prefix for this)
GEMMA_API_KEY=

# Optional: override the Gemma model id used by /api/ai/* (defaults to gemma-4-26b-a4b-it)
GEMMA_MODEL=gemma-4-26b-a4b-it

# Optional: shared secret to protect the weekly /api/ai/refresh-profiles cron.
# Set the SAME value here and in Vercel; Vercel Cron sends it as a Bearer token.
CRON_SECRET=

# Seed script ONLY (server-side, secret — never committed, never VITE_)
SUPABASE_SERVICE_ROLE_KEY=
