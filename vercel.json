{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai/chat.ts": { "maxDuration": 30 },
    "api/ai/refresh-profiles.ts": { "maxDuration": 60 }
  },
  "crons": [{ "path": "/api/ai/refresh-profiles", "schedule": "0 6 * * 1" }],
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
