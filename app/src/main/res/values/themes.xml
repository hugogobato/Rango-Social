<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. Compose drives the actual styling; this exists for
         pre-Compose system bars, dialogs, and the splash screen. -->
    <style name="Theme.GuruDosRestaurantes" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="colorSecondary">@color/secondary_purple</item>
        <item name="colorTertiary">@color/accent_teal</item>
        <item name="colorError">@color/error_red</item>
    </style>

    <!-- Splash screen theme: shown while Application/MainActivity boot. -->
    <style name="Theme.GuruDosRestaurantes.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.GuruDosRestaurantes</item>
    </style>

</resources>
