# Production build env (read by Vite during `vite build` — this is what Vercel runs).
# Only VITE_* vars here, and ONLY public-safe values: the Supabase URL and the
# anon/publishable key are designed to be public (they ship in the client bundle;
# RLS protects the data). NEVER put SERVICE_ROLE_KEY / GEMMA_API_KEY here — those
# stay as server-only env vars in the Vercel dashboard.
VITE_DATA_SOURCE=supabase
VITE_SUPABASE_URL=https://nlgqejyygyszmettdxiz.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_87jFn9APp52lD6UgJgQkBg_VGAZrcaU
